    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Get ORIGINAL INPUT (Reaching back to the Webhook node)\n// This ensures 'type', 'chatInput', and 'rules_context' are preserved\nconst originalInput = $('Trigger Entry Webhook').item.json.body;\n\n// 2. Get the raw response from the Agent for Validation\nconst rawText = $('Agent for Validation').item.json.output || \n                $('Agent for Validation').item.json.text || \"\";\n\n// 3. Clean and Parse\ntry {\n  const cleanJson = rawText.replace(/```json|```/g, \"\").trim();\n  const parsed = JSON.parse(cleanJson);\n  \n  // 4. RETURN EVERYTHING (The Complete JSON)\n  return {\n    type: originalInput.type,\n    chatInput: originalInput.chatInput,\n    rules_context: originalInput.rules_context, // Keeping this as requested\n    isPenalice: parsed.isPenalice,\n    penaliceTitles: parsed.penaliceTitles || []\n  };\n\n} catch (e) {\n  // If AI output is unreadable, we still return the full structure to prevent crashes\n  return {\n    type: originalInput.type,\n    chatInput: originalInput.chatInput,\n    rules_context: originalInput.rules_context,\n    isPenalice: true, \n    penaliceTitles: [\"JSON_PARSE_ERROR\"]\n  };\n}"
      },
