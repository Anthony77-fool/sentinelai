    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Try to find the rules in common locations (body or top level)\nconst rawData = $json.rules || ($json.body && $json.body.rules);\n\n// 2. Initialize the string\nlet ruleString = \"SENTINEL AI: UPDATED PRIVACY RULES\\n\";\nruleString += \"====================================\\n\";\n\n// 3. Check if rawData actually has content\nif (!rawData) {\n    ruleString += \"ERROR: No rules data was received from the previous node.\";\n} else if (typeof rawData === 'string') {\n    ruleString += rawData;\n} else {\n    // Loop through object keys\n    for (const key in rawData) {\n        if (key !== 'type') { \n            ruleString += `- ${key}: ${rawData[key]}\\n`;\n        }\n    }\n}\n\n// 4. Return it as rules_text\nreturn { \n  rules_text: ruleString,\n  update_time: new Date().toLocaleString()\n};"
      },
