    {
      "parameters": {
        "promptType": "define",
        "text": "=User Input: {{ $json.chatInput }}\nRules to Follow: {{ $json.rules_context }}\n\nRespond using this JSON structure:\n{\n  \"type\": \"{{ $json.body.type }}\",\n  \"chatInput\": \"{{ $json.chatInput }}\",\n  \"rules_context\": \"{{ $json.rules_context }}\",\n  \"isPenalice\": boolean,\n  \"penaliceTitles\": [\"Title 1\", \"Title 2\"] or null\n}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict security validator for SentinelAI. Your task is to analyze the chatInput based on the provided rules_context.  Logic:  Check if chatInput violates any rule in rules_context.  If it violates a rule: set isPenalice to true and list the specific rule titles in penaliceTitles.  If it is safe: set isPenalice to false and penaliceTitles to null.  Always return the original chatInput regardless of the result.  Output Format: You MUST respond in valid JSON format only."
            }
          ]
        },
        "batching": {}
